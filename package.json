    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^4.0.2",
    "nodemailer": "^8.0.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node-cron": "^3.0.11",
